    },
    "Please allow MindfulPacer to access your Apple Health data. Select the biometric data that you want to share (e.g. heart rate and/or steps)." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte erlaube MindfulPacer den Zugriff auf deine Apple Gesundheits-Daten. Wähle die biometrischen Daten aus, die du teilen möchtest (z.B. Herzfrequenz und/oder Schritte)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por favor, permite que MindfulPacer acceda a tus datos de Apple Salud. Selecciona los datos biométricos que deseas compartir (p. ej., frecuencia cardíaca y/o pasos)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez autoriser MindfulPacer à accéder à vos données Apple Santé. Sélectionnez les données biométriques que vous souhaitez partager (par ex. fréquence cardiaque et/ou pas)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consenti a MindfulPacer di accedere ai tuoi dati di Apple Salute. Seleziona i dati biometrici che desideri condividere (ad es. frequenza cardiaca e/o passi)."
          }
        }
      }
    },
    "Please allow MindfulPacer to send notifications to receive the Reminders." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte erlaube MindfulPacer, Mitteilungen zu senden, um die Erinnerungen zu erhalten."
