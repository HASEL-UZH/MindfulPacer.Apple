        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durée pendant laquelle la fréquence cardiaque doit être supérieure ou égale au seuil (seuil sélectionné sur la page précédente) pour que le rappel soit déclenché."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
