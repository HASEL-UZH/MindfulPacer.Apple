          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empareja MindfulPacer con tu Apple Watch para recopilar automáticamente datos de salud, recordatorios y seguimiento de actividad junto con tus reflexiones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
