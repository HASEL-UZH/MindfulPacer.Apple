            "state" : "translated",
            "value" : "Questo ti permette di aggiungere un nuovo promemoria che può essere attivato sul tuo Apple Watch o iPhone."
          }
        }
      }
    },
    "This chart displays heart rate data from the last hour." : {
      "comment" : "A message displayed in an alert when a user taps the info button in the heart rate chart view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Diagramm zeigt die Herzfrequenzdaten der letzten Stunde an."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce graphique affiche les données de fréquence cardiaque de la dernière heure."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo grafico mostra i dati della frequenza cardiaca dell'ultima ora."
