    "Diagnostics were copied to your clipboard.\n\nIf Mail is not set up, please paste them into an email and send to:\n%@" : {
      "comment" : "An alert message explaining that the diagnostics have been copied to the user's clipboard, and also providing instructions on how to send them via email. The argument is the string “support@mindfulpacer.com”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Diagnosedaten wurden in die Zwischenablage kopiert.\n\nFalls Mail nicht eingerichtet ist, füge sie bitte in eine E-Mail ein und sende sie an:\n%@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los diagnósticos se copiaron al portapapeles.\n\nSi el correo no está configurado, pégalos en un email y envíalo a:\n%@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les diagnostics ont été copiés dans votre presse-papiers.\n\nSi Mail n'est pas configuré, veuillez les coller dans un e-mail et envoyer à :\n%@"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La diagnostica è stata copiata negli appunti.\n\nSe Mail non è configurato, incollala in un'email e invia a:\n%@"
          }
        }
      }
    },
