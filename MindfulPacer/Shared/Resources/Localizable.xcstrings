    "Add our status complication to your favorite watch face to instantly see if monitoring is active or inactive." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füge unsere Statuskomplikation zu deinem bevorzugten Zifferblatt hinzu, um sofort zu sehen, ob das Monitoring aktiv oder inaktiv ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade nuestra complicación de estado a tu esfera favorita para ver al instante si el monitoreo está activo o inactivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez notre complication de statut à votre cadran préféré pour voir instantanément si le monitoring est actif ou inactif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi la nostra complicazione di stato al tuo quadrante preferito per vedere istantaneamente se il monitoraggio è attivo o inattivo."
          }
        }
      }
    },
    "Add reflections on your activities, energy management, moods and symptoms." : {
