    "**NOTE:** Only highlighted points are considered for the missed reflection." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**HINWEIS:** Nur die markierten Datenpunkte wurden für die verpassten Reflexionen verwendet."
