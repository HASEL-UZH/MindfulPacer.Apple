    "Unable to save your Reflection.\nPlease try again.\nIf this problem persists, please contact us." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Reflexion konnte nicht gespeichert werden.\nBitte versuche es erneut.\nWenn dieses Problem weiterhin besteht, kontaktiere uns bitte."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo guardar tu reflexión.\nPor favor, inténtalo de nuevo.\nSi el problema persiste, contáctanos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible d'enregistrer votre réflexion.\nVeuillez réessayer.\nSi le problème persiste, veuillez nous contacter."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossibile salvare la tua riflessione.\nRiprova.\nSe il problema persiste, contattaci."
          }
        }
      }
    },
    "Unable to save your Reminder.\nPlease try again.\nIf this problem persists, please contact us." : {
