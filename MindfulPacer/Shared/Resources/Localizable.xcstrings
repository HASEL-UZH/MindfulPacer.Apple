      }
    },
    "This chart displays step data from the last hour." : {
      "comment" : "A message displayed in an alert when a user taps the info button in the steps chart view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Diagramm zeigt die Schrittzahl der letzten Stunde an."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
