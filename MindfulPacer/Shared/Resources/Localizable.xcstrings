    "This setting can keep MindfulPacer on screen while a session is active. If you don’t see it right away, don’t worry - it can take a little time to appear." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Einstellung kann MindfulPacer während einer aktiven Sitzung auf dem Bildschirm halten. Wenn sie nicht sofort angezeigt wird, keine Sorge – es kann einen Moment dauern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este ajuste puede mantener MindfulPacer en pantalla mientras una sesión esté activa. Si no lo ves de inmediato, no te preocupes, puede tardar un poco en aparecer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce réglage peut garder MindfulPacer à l'écran pendant qu'une session est active. Si vous ne le voyez pas tout de suite, ne vous inquiétez pas – cela peut prendre un peu de temps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa impostazione può mantenere MindfulPacer sullo schermo durante una sessione attiva. Se non lo vedi subito, non preoccuparti – potrebbe richiedere un po' di tempo."
          }
        }
      }
    },
    "This setting is optional. MindfulPacer will work normally even if your watch returns to the clock." : {
      "comment" : "A note displayed below the information about the optional setting.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Einstellung ist optional. MindfulPacer funktioniert normal, auch wenn deine Watch zur Uhr zurückkehrt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este ajuste es opcional. MindfulPacer funcionará normalmente aunque tu reloj vuelva a la esfera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce réglage est facultatif. MindfulPacer fonctionnera normalement même si votre montre revient au cadran."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa impostazione è facoltativa. MindfulPacer funzionerà normalmente anche se il tuo orologio torna al quadrante."
          }
        }
      }
    },
    "This will permanently remove your reflections, reminders, cached health data, and settings from this device. This action cannot be undone." : {
      "comment" : "An alert message explaining that deleting all user data cannot be undone.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden deine Reflexionen, Erinnerungen, zwischengespeicherten Gesundheitsdaten und Einstellungen dauerhaft von diesem Gerät entfernt. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará permanentemente tus reflexiones, recordatorios, datos de salud en caché y ajustes de este dispositivo. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera définitivement vos réflexions, rappels, données de santé en cache et réglages de cet appareil. Cette action est irréversible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa operazione rimuoverà permanentemente le tue riflessioni, promemoria, dati sulla salute in cache e impostazioni da questo dispositivo. Questa azione è irreversibile."
          }
        }
      }
    },
