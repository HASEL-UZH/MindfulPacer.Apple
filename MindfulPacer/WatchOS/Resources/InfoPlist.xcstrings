    "NSHealthShareUsageDescription" : {
      "comment" : "Privacy - Health Share Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Zugriff auf Gesundheitsdaten für Herzfrequenz und Schrittanzahl erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This app reads your heart rate to detect high heart rate events and reads your step count to alert you based on your activity goals."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette app lit votre fréquence cardiaque pour détecter les événements de fréquence cardiaque élevée et lit votre nombre de pas pour vous alerter en fonction de vos objectifs d'activité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa app legge la tua frequenza cardiaca per rilevare eventi di frequenza cardiaca elevata e legge il conteggio dei passi per avvisarti in base ai tuoi obiettivi di attività."
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "comment" : "Privacy - Health Update Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Zugriff auf Gesundheitsdaten für Herzfrequenz und Schrittanzahl erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This app creates workout sessions in the background to monitor your heart rate continuously."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette app crée des sessions d'entraînement en arrière-plan pour surveiller votre fréquence cardiaque en continu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa app crea sessioni di allenamento in background per monitorare continuamente la tua frequenza cardiaca."
